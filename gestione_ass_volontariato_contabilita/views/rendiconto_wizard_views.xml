<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rendiconto_wizard_form" model="ir.ui.view">
        <field name="name">volontariato.rendiconto.wizard.form</field>
        <field name="model">volontariato.rendiconto.wizard</field>
        <field name="arch" type="xml">
            <form string="Rendiconto per Cassa">
                <group>
                    <field name="anno"/>
                    <field name="company_id"/>
                </group>
                <footer>
                    <button name="action_stampa" type="object"
                            string="Stampa PDF" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_rendiconto_wizard" model="ir.actions.act_window">
        <field name="name">Rendiconto per Cassa</field>
        <field name="res_model">volontariato.rendiconto.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
