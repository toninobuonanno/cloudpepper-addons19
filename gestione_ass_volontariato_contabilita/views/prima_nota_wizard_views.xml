<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_prima_nota_wizard_form" model="ir.ui.view">
        <field name="name">volontariato.prima.nota.wizard.form</field>
        <field name="model">volontariato.prima.nota.wizard</field>
        <field name="arch" type="xml">
            <form string="Nuovo Movimento">
                <group>
                    <group>
                        <field name="company_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="intervento_id" invisible="1"/>
                        <field name="tipo" widget="radio" options="{'horizontal': true}"/>
                        <field name="data"/>
                        <field name="importo"/>
                        <field name="journal_id" options="{'no_create': True}"/>
                    </group>
                    <group>
                        <field name="conto_natura_id" options="{'no_create': True}"/>
                        <field name="analitica_id" options="{'no_quick_create': True}"/>
                        <field name="partner_id"/>
                    </group>
                </group>
                <group>
                    <field name="descrizione"/>
                </group>
                <footer>
                    <button name="action_registra" type="object"
                            string="Registra" class="btn-primary"/>
                    <button string="Annulla" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_prima_nota_wizard" model="ir.actions.act_window">
        <field name="name">Nuovo Movimento</field>
        <field name="res_model">volontariato.prima.nota.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
