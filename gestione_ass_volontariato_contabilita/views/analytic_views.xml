<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_analytic_account_form_sezione" model="ir.ui.view">
        <field name="name">account.analytic.account.form.sezione</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_form"/>
        <field name="arch" type="xml">
            <field name="plan_id" position="after">
                <field name="sezione_rendiconto_id"/>
            </field>
        </field>
    </record>
    <record id="view_analytic_account_list_sezione" model="ir.ui.view">
        <field name="name">account.analytic.account.list.sezione</field>
        <field name="model">account.analytic.account</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_account_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="sezione_rendiconto_id" optional="show"/>
            </xpath>
        </field>
    </record>
    <record id="action_destinazioni" model="ir.actions.act_window">
        <field name="name">Destinazioni</field>
        <field name="res_model">account.analytic.account</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
