<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_turno_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>
                            Turno <span t-field="o.codice"/>
                        </h2>
                        <table class="table table-sm" style="margin-top: 12px;">
                            <tr>
                                <td><strong>Evento:</strong></td>
                                <td><span t-field="o.evento"/></td>
                                <td><strong>Luogo:</strong></td>
                                <td><span t-field="o.luogo"/></td>
                            </tr>
                            <tr>
                                <td><strong>Data:</strong></td>
                                <td><span t-field="o.data"/></td>
                                <td><strong>Orario:</strong></td>
                                <td>
                                    <span t-field="o.ora_inizio" t-options='{"widget": "float_time"}'/>
                                    -
                                    <span t-field="o.ora_fine" t-options='{"widget": "float_time"}'/>
                                </td>
                            </tr>
                        </table>

                        <h3 style="margin-top: 20px;">Volontari Partecipanti</h3>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr style="background-color: #2c3e50; color: white;">
                                    <th>Ruolo</th>
                                    <th>Nome e Cognome</th>
                                    <th>Qualifica</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="o.squadra_ids" t-as="riga">
                                    <tr>
                                        <td><span t-field="riga.ruolo"/></td>
                                        <td><span t-esc="riga.employee_id.name"/></td>
                                        <td><span t-esc="riga.qualifica_id.name or ''"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <t t-if="o.note">
                            <h3 style="margin-top: 20px;">Note</h3>
                            <p><span t-field="o.note"/></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_turno" model="ir.actions.report">
        <field name="name">Turno - Dettaglio</field>
        <field name="model">volontariato.turno</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">gestione_ass_volontariato.report_turno_document</field>
        <field name="report_file">gestione_ass_volontariato.report_turno_document</field>
        <field name="binding_model_id" ref="model_volontariato_turno"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Turno_%s' % (object.codice or 'Nuovo')</field>
    </record>

</odoo>
