<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_certificazione_volontario_list" model="ir.ui.view">
        <field name="name">volontariato.certificazione.volontario.list</field>
        <field name="model">volontariato.certificazione.volontario</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="tipo_cert_id"/>
                <field name="data_conseguimento"/>
                <field name="data_scadenza"
                       decoration-danger="stato_scadenza == 'expired'"
                       decoration-warning="stato_scadenza == 'warn'"
                       decoration-success="stato_scadenza == 'ok'"/>
                <field name="stato_scadenza" widget="badge"
                       decoration-danger="stato_scadenza == 'expired'"
                       decoration-warning="stato_scadenza == 'warn'"
                       decoration-success="stato_scadenza == 'ok'"
                       decoration-muted="stato_scadenza == 'none'"/>
            </list>
        </field>
    </record>

    <!-- ═══════════ VISTA TRASVERSALE: tutte le certificazioni di tutti i volontari ═══════════ -->
    <record id="view_certificazione_volontario_list_global" model="ir.ui.view">
        <field name="name">volontariato.certificazione.volontario.list.global</field>
        <field name="model">volontariato.certificazione.volontario</field>
        <field name="arch" type="xml">
            <list decoration-danger="stato_scadenza == 'expired'" decoration-warning="stato_scadenza == 'warn'">
                <field name="employee_id" string="Volontario"/>
                <field name="tipo_cert_id" string="Tipo Certificazione"/>
                <field name="data_conseguimento"/>
                <field name="data_scadenza"/>
                <field name="stato_scadenza" widget="badge"
                       decoration-danger="stato_scadenza == 'expired'"
                       decoration-warning="stato_scadenza == 'warn'"
                       decoration-success="stato_scadenza == 'ok'"
                       decoration-muted="stato_scadenza == 'none'"
                       optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_certificazione_volontario_search_global" model="ir.ui.view">
        <field name="name">volontariato.certificazione.volontario.search.global</field>
        <field name="model">volontariato.certificazione.volontario</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="tipo_cert_id"/>
                <filter string="Scadute" name="cert_expired" domain="[('stato_scadenza', '=', 'expired')]"/>
                <filter string="In Scadenza" name="cert_warn" domain="[('stato_scadenza', '=', 'warn')]"/>
                <filter string="Valide" name="cert_ok" domain="[('stato_scadenza', '=', 'ok')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Volontario" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Tipo Certificazione" name="group_tipo" context="{'group_by': 'tipo_cert_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_volontariato_certificazione_volontario_global" model="ir.actions.act_window">
        <field name="name">Certificazioni Volontari</field>
        <field name="res_model">volontariato.certificazione.volontario</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_certificazione_volontario_list_global"/>
        <field name="search_view_id" ref="view_certificazione_volontario_search_global"/>
    </record>

</odoo>
