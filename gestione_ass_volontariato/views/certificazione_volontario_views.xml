<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_certificazione_volontario_list" model="ir.ui.view">
        <field name="name">volontariato.certificazione.volontario.list</field>
        <field name="model">volontariato.certificazione.volontario</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="tipo_cert_id"/>
                <field name="data_conseguimento"/>
                <field name="data_scadenza"/>
                <field name="stato_scadenza" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_volontariato_certificazione_volontario_global" model="ir.actions.act_window">
        <field name="name">Certificazioni Volontari</field>
        <field name="res_model">volontariato.certificazione.volontario</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
