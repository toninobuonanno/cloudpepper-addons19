<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_volontariato_impegno_volontari_list" model="ir.ui.view">
        <field name="name">volontariato.turno.squadra.impegno.list</field>
        <field name="model">volontariato.turno.squadra</field>
        <field name="arch" type="xml">
            <list string="Impegno Volontari">
                <field name="employee_id" string="Volontario"/>
                <field name="ruolo_id"/>
                <field name="turno_id" string="Turno"/>
                <field name="data"/>
                <field name="evento"/>
                <field name="luogo"/>
                <field name="ora_inizio" widget="float_time"/>
                <field name="ora_fine" widget="float_time"/>
                <field name="durata_ore" widget="float_time" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_volontariato_impegno_volontari_search" model="ir.ui.view">
        <field name="name">volontariato.turno.squadra.impegno.search</field>
        <field name="model">volontariato.turno.squadra</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="evento"/>
                <field name="luogo"/>
                <field name="data"/>
                <filter string="Caposquadra" name="filter_caposquadra" domain="[('ruolo_id.name', '=', 'Caposquadra')]"/>
                <filter string="Autista" name="filter_autista" domain="[('ruolo_id.name', '=', 'Autista')]"/>
                <filter string="Volontario" name="filter_volontario" domain="[('ruolo_id.name', '=', 'Volontario')]"/>
            </search>
        </field>
    </record>

    <record id="action_volontariato_impegno_volontari" model="ir.actions.act_window">
        <field name="name">Impegno Volontari</field>
        <field name="res_model">volontariato.turno.squadra</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_volontariato_impegno_volontari_list"/>
    </record>

</odoo>
