<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_volontariato_impegno_volontari_list" model="ir.ui.view">
        <field name="name">volontariato.turno.squadra.impegno.list</field>
        <field name="model">volontariato.turno.squadra</field>
        <field name="arch" type="xml">
            <list string="Impegno Volontari">
                <field name="employee_id" string="Volontario"/>
                <field name="ruolo"/>
                <field name="turno_id" string="Turno"/>
                <field name="data"/>
                <field name="evento"/>
                <field name="luogo"/>
                <field name="ora_inizio" widget="float_time"/>
                <field name="ora_fine" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_volontariato_impegno_volontari_search" model="ir.ui.view">
        <field name="name">volontariato.turno.squadra.impegno.search</field>
        <field name="model">volontariato.turno.squadra</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="evento"/>
                <field name="luogo"/>
                <field name="data"/>
                <filter string="Caposquadra" name="filter_caposquadra" domain="[('ruolo', '=', 'caposquadra')]"/>
                <filter string="Autista" name="filter_autista" domain="[('ruolo', '=', 'autista')]"/>
                <filter string="Volontario" name="filter_volontario" domain="[('ruolo', '=', 'volontario')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Volontario" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="Ruolo" name="group_ruolo" context="{'group_by': 'ruolo'}"/>
                    <filter string="Evento" name="group_evento" context="{'group_by': 'evento'}"/>
                    <filter string="Data" name="group_data" context="{'group_by': 'data'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_volontariato_impegno_volontari" model="ir.actions.act_window">
        <field name="name">Impegno Volontari</field>
        <field name="res_model">volontariato.turno.squadra</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_volontariato_impegno_volontari_list"/>
    </record>

</odoo>
