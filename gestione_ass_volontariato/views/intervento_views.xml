<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════ FORM VIEW ═══════════ -->
    <record id="view_volontariato_intervento_form" model="ir.ui.view">
        <field name="name">volontariato.intervento.form</field>
        <field name="model">volontariato.intervento</field>
        <field name="arch" type="xml">
            <form string="Foglio di Viaggio">
                <header/>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="codice" readonly="1"/>
                        </h1>
                    </div>

                    <!-- ═══ SEZIONE 1 — Dati Intervento ═══ -->
                    <group string="Sezione 1 — Dati dell'Intervento">
                        <group>
                            <field name="vehicle_id"/>
                            <field name="tipo_intervento"/>
                            <field name="data"/>
                            <field name="km_totali"/>
                        </group>
                        <group>
                            <field name="ora_inizio" widget="float_time"/>
                            <field name="ora_fine" widget="float_time"/>
                            <field name="km_iniziali"/>
                            <field name="km_finali"/>
                        </group>
                        <group>
                            <field name="ora_arrivo_luogo" widget="float_time"/>
                            <field name="ora_partenza_luogo" widget="float_time"/>
                            <field name="ora_arrivo_dest" widget="float_time"/>
                            <field name="durata_ore" widget="float_time" readonly="1"/>
                        </group>
                        <group string="Richiedente">
                            <field name="richiedente"/>
                            <field name="richiedente_citta"/>
                            <field name="richiedente_provincia"/>
                        </group>
                        <group string="Luogo">
                            <field name="luogo"/>
                            <field name="luogo_citta"/>
                            <field name="luogo_provincia"/>
                            <field name="luogo_destinazione"/>
                        </group>
                    </group>

                    <group string="Rifornimento / Pulizia / Offerta">
                        <group>
                            <field name="rifornimento"/>
                            <field name="rifornimento_euro" invisible="not rifornimento"/>
                            <field name="rifornimento_litri" invisible="not rifornimento"/>
                        </group>
                        <group>
                            <field name="pulizia"/>
                        </group>
                        <group>
                            <field name="offerta"/>
                            <field name="offerta_euro" invisible="not offerta"/>
                            <field name="offerta_ricevuta" invisible="not offerta"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- ═══ SEZIONE 2 — Squadra ═══ -->
                        <page string="Sezione 2 — Squadra" name="squadra">
                            <field name="squadra_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="ruolo"/>
                                    <field name="employee_id"/>
                                </list>
                            </field>
                            <group>
                                <field name="numero_volontari" readonly="1"/>
                            </group>
                            <separator string="Note"/>
                            <field name="note" placeholder="Modalità di svolgimento e annotazioni..."/>
                        </page>

                        <!-- ═══ SEZIONE 3 — Paziente ═══ -->
                        <page string="Sezione 3 — Dati Anagrafici Paziente" name="paziente">
                            <field name="paziente_ids">
                                <list editable="bottom">
                                    <field name="cognome_nome"/>
                                    <field name="nato_a"/>
                                    <field name="nato_il"/>
                                    <field name="residente_a"/>
                                    <field name="indirizzo"/>
                                    <field name="professione"/>
                                    <field name="sospetta_diagnosi"/>
                                    <field name="causato_da"/>
                                </list>
                            </field>
                        </page>

                        <!-- ═══ SEZIONE 4 — Consensi ═══ -->
                        <page string="Sezione 4 — Consensi" name="consensi">
                            <field name="consenso_ids">
                                <list editable="bottom">
                                    <field name="consenso_fornito" widget="boolean_toggle"/>
                                    <field name="rifiuto_ricovero" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════ LIST VIEW ═══════════ -->
    <record id="view_volontariato_intervento_list" model="ir.ui.view">
        <field name="name">volontariato.intervento.list</field>
        <field name="model">volontariato.intervento</field>
        <field name="arch" type="xml">
            <list>
                <field name="codice"/>
                <field name="data"/>
                <field name="vehicle_id"/>
                <field name="tipo_intervento"/>
                <field name="richiedente"/>
                <field name="luogo"/>
                <field name="km_totali" sum="Km Totali"/>
                <field name="caposquadra_id"/>
            </list>
        </field>
    </record>

    <!-- ═══════════ SEARCH VIEW ═══════════ -->
    <record id="view_volontariato_intervento_search" model="ir.ui.view">
        <field name="name">volontariato.intervento.search</field>
        <field name="model">volontariato.intervento</field>
        <field name="arch" type="xml">
            <search>
                <field name="codice"/>
                <field name="vehicle_id"/>
                <field name="richiedente"/>
                <field name="luogo"/>
                <field name="caposquadra_id"/>
                <filter string="Oggi" name="oggi" domain="[('data', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter string="Questo Mese" name="mese_corrente"
                        domain="[('data', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Emergenza" name="emergenza" domain="[('tipo_intervento', '=', 'emergenza')]"/>
                <filter string="Assistenza" name="assistenza" domain="[('tipo_intervento', '=', 'assistenza')]"/>
                <filter string="Trasporto" name="trasporto" domain="[('tipo_intervento', '=', 'trasporto')]"/>
                <group expand="0" string="Raggruppa per">
                    <filter string="Automezzo" name="group_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Tipo Intervento" name="group_tipo" context="{'group_by': 'tipo_intervento'}"/>
                    <filter string="Caposquadra" name="group_capo" context="{'group_by': 'caposquadra_id'}"/>
                    <filter string="Data" name="group_data" context="{'group_by': 'data'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══════════ ACTION ═══════════ -->
    <record id="action_volontariato_intervento" model="ir.actions.act_window">
        <field name="name">Registro Interventi</field>
        <field name="res_model">volontariato.intervento</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_volontariato_intervento_search"/>
        <field name="context">{'search_default_mese_corrente': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea il tuo primo Foglio di Viaggio
            </p>
        </field>
    </record>

</odoo>
