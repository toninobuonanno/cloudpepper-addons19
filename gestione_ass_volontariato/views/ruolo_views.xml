<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_volontariato_ruolo_list" model="ir.ui.view">
        <field name="name">volontariato.ruolo.list</field>
        <field name="model">volontariato.ruolo</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_responsabile"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_volontariato_ruolo" model="ir.actions.act_window">
        <field name="name">Ruoli Squadra/Turno</field>
        <field name="res_model">volontariato.ruolo</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
