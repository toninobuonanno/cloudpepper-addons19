<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tipologia esercitazione: lookup table -->
    <record id="view_volontariato_tipo_esercitazione_list" model="ir.ui.view">
        <field name="name">volontariato.tipo.esercitazione.list</field>
        <field name="model">volontariato.tipo.esercitazione</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_volontariato_tipo_esercitazione" model="ir.actions.act_window">
        <field name="name">Tipologie Esercitazione</field>
        <field name="res_model">volontariato.tipo.esercitazione</field>
        <field name="view_mode">list</field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_volontariato_esercitazione_form" model="ir.ui.view">
        <field name="name">volontariato.esercitazione.form</field>
        <field name="model">volontariato.esercitazione</field>
        <field name="arch" type="xml">
            <form string="Esercitazione">
                <header>
                    <button name="action_add_to_calendar" type="object" string="Aggiungi a Calendario"
                            class="oe_highlight" icon="fa-calendar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="codice" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Dati Esercitazione">
                            <field name="tipo_id"/>
                            <field name="data"/>
                            <field name="ora_inizio" widget="float_time"/>
                            <field name="ora_fine" widget="float_time"/>
                            <field name="durata_ore" widget="float_time" readonly="1"/>
                        </group>
                        <group string="Descrizione">
                            <field name="descrizione"/>
                            <field name="numero_partecipanti" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Volontari Partecipanti" name="partecipanti">
                            <field name="partecipante_ids" widget="many2many_tags" placeholder="Seleziona i volontari partecipanti..."/>
                        </page>

                        <page string="Note" name="note">
                            <field name="note" nolabel="1" placeholder="Note aggiuntive sull'esercitazione..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- LIST VIEW -->
    <record id="view_volontariato_esercitazione_list" model="ir.ui.view">
        <field name="name">volontariato.esercitazione.list</field>
        <field name="model">volontariato.esercitazione</field>
        <field name="arch" type="xml">
            <list>
                <field name="codice"/>
                <field name="data"/>
                <field name="tipo_id"/>
                <field name="descrizione"/>
                <field name="durata_ore" widget="float_time" optional="hide"/>
                <field name="numero_partecipanti"/>
            </list>
        </field>
    </record>

    <!-- SEARCH VIEW -->
    <record id="view_volontariato_esercitazione_search" model="ir.ui.view">
        <field name="name">volontariato.esercitazione.search</field>
        <field name="model">volontariato.esercitazione</field>
        <field name="arch" type="xml">
            <search>
                <field name="codice"/>
                <field name="tipo_id"/>
                <field name="descrizione"/>
                <field name="partecipante_ids"/>
                <field name="data"/>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_volontariato_esercitazione" model="ir.actions.act_window">
        <field name="name">Registro Esercitazioni</field>
        <field name="res_model">volontariato.esercitazione</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_volontariato_esercitazione_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea la tua prima Esercitazione
            </p>
        </field>
    </record>

</odoo>
