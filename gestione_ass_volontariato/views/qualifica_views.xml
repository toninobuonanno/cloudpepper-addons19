<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_volontariato_qualifica_list" model="ir.ui.view">
        <field name="name">volontariato.qualifica.list</field>
        <field name="model">volontariato.qualifica</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_volontariato_qualifica" model="ir.actions.act_window">
        <field name="name">Qualifiche Volontari</field>
        <field name="res_model">volontariato.qualifica</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
