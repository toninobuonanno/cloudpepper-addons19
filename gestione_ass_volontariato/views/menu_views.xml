<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Menu radice del modulo -->
    <menuitem id="menu_volontariato_root"
              name="Volontariato"
              sequence="50"
              web_icon="gestione_ass_volontariato,static/description/icon.svg"/>

    <!-- Registro Interventi: voce principale, subito visibile -->
    <menuitem id="menu_volontariato_interventi"
              name="Registro Interventi"
              parent="menu_volontariato_root"
              action="action_volontariato_intervento"
              sequence="10"/>

    <!-- Sotto-menu Configurazione -->
    <menuitem id="menu_volontariato_config"
              name="Configurazione"
              parent="menu_volontariato_root"
              sequence="90"/>

    <!-- Automezzi: azione propria che punta al modello fleet.vehicle nativo -->
    <record id="action_volontariato_automezzi" model="ir.actions.act_window">
        <field name="name">Automezzi</field>
        <field name="res_model">fleet.vehicle</field>
        <field name="view_mode">list,form,kanban</field>
    </record>
    <menuitem id="menu_volontariato_automezzi"
              name="Automezzi"
              parent="menu_volontariato_root"
              sequence="20"/>

    <menuitem id="menu_volontariato_automezzi_lista"
              name="Veicoli"
              parent="menu_volontariato_automezzi"
              action="action_volontariato_automezzi"
              sequence="5"/>

    <!-- Contratti Automezzi: punta al modello nativo fleet.vehicle.log.contract,
         senza specificare view_id così Odoo usa le viste native di Fleet
         (list, kanban, graph, pivot già pronte e testate) -->
    <record id="action_volontariato_contratti_automezzi" model="ir.actions.act_window">
        <field name="name">Contratti Automezzi</field>
        <field name="res_model">fleet.vehicle.log.contract</field>
        <field name="view_mode">list,form,kanban,graph,pivot</field>
    </record>
    <menuitem id="menu_volontariato_contratti_automezzi"
              name="Contratti"
              parent="menu_volontariato_automezzi"
              action="action_volontariato_contratti_automezzi"
              sequence="10"/>

    <!-- Volontari: azione propria che punta al modello hr.employee nativo,
         filtrato sulla Posizione Lavorativa (job_id) con nome "Volontario".
         Questo richiede che esista una hr.job con nome esatto "Volontario";
         se non esiste ancora, crearla da Dipendenti > Reclutamento > Posizioni Lavorative,
         oppure aprire un dipendente e scrivere "Volontario" nel campo Posizione Lavorativa. -->
    <record id="action_volontariato_volontari" model="ir.actions.act_window">
        <field name="name">Volontari</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('job_id.name', '=', 'Volontario')]</field>
    </record>
    <menuitem id="menu_volontariato_volontari"
              name="Volontari"
              parent="menu_volontariato_root"
              sequence="30"/>

    <menuitem id="menu_volontariato_volontari_lista"
              name="Elenco"
              parent="menu_volontariato_volontari"
              action="action_volontariato_volontari"
              sequence="5"/>

    <!-- Certificazioni Volontari: vista trasversale di tutte le certificazioni -->
    <menuitem id="menu_volontariato_certificazioni_volontari"
              name="Certificazioni"
              parent="menu_volontariato_volontari"
              action="action_volontariato_certificazione_volontario_global"
              sequence="10"/>

    <!-- Azione secondaria, senza filtro, per vedere TUTTI i dipendenti
         (utile se la posizione "Volontario" non è ancora configurata o
         per gestire anche dipendenti non-volontari dalla stessa app) -->
    <record id="action_volontariato_dipendenti_tutti" model="ir.actions.act_window">
        <field name="name">Tutti i Dipendenti</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
    <menuitem id="menu_volontariato_dipendenti_tutti"
              name="Tutti i Dipendenti"
              parent="menu_volontariato_root"
              action="action_volontariato_dipendenti_tutti"
              sequence="31"/>

    <!-- Dispositivi: l'azione action_volontariato_dispositivi è definita
         in maintenance_equipment_views.xml (con vista list personalizzata) -->
    <menuitem id="menu_volontariato_dispositivi"
              name="Dispositivi"
              parent="menu_volontariato_root"
              sequence="40"/>

    <menuitem id="menu_volontariato_dispositivi_lista"
              name="Elenco"
              parent="menu_volontariato_dispositivi"
              action="action_volontariato_dispositivi"
              sequence="5"/>

    <!-- Certificazioni/Revisioni Dispositivi: vista trasversale -->
    <menuitem id="menu_volontariato_certificazioni_dispositivi"
              name="Certificazioni / Revisioni"
              parent="menu_volontariato_dispositivi"
              action="action_volontariato_certificazione_attrezzatura_global"
              sequence="10"/>

    <!-- Contratti generali: modello custom proprio del modulo -->
    <menuitem id="menu_volontariato_contratti"
              name="Contratti e Assicurazioni"
              parent="menu_volontariato_root"
              action="action_volontariato_contratto"
              sequence="50"/>

    <!-- Dashboard: cruscotti statistiche con filtro data -->
    <menuitem id="menu_volontariato_dashboard"
              name="Dashboard"
              parent="menu_volontariato_root"
              sequence="60"/>

    <menuitem id="menu_volontariato_dashboard_interventi"
              name="Interventi"
              parent="menu_volontariato_dashboard"
              action="action_volontariato_dashboard_interventi"
              sequence="10"/>

    <menuitem id="menu_volontariato_dashboard_volontari"
              name="Volontari"
              parent="menu_volontariato_dashboard"
              action="action_volontariato_dashboard_volontari"
              sequence="20"/>

    <menuitem id="menu_volontariato_qualifica"
              name="Qualifiche Volontari"
              parent="menu_volontariato_config"
              action="action_volontariato_qualifica"
              sequence="10"/>

    <menuitem id="menu_volontariato_tipo_cert_volontario"
              name="Tipi Certificazione Volontari"
              parent="menu_volontariato_config"
              action="action_volontariato_tipo_cert_volontario"
              sequence="20"/>

    <menuitem id="menu_volontariato_tipo_cert_attrezzatura"
              name="Tipi Certificazione Attrezzature"
              parent="menu_volontariato_config"
              action="action_volontariato_tipo_cert_attrezzatura"
              sequence="30"/>

    <menuitem id="menu_volontariato_tipo_contratto"
              name="Tipi Contratto / Assicurazione"
              parent="menu_volontariato_config"
              action="action_volontariato_tipo_contratto"
              sequence="40"/>

</odoo>
